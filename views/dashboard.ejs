<%- include("partials/header") %>

    <div class="container-fluid bg-light" style="min-height: calc(100vh - 70px);">
    <div class="row h-100">

        <!-- ═══════════════════════════════════════════════════════════
             SIDEBAR — Your Library
             ═══════════════════════════════════════════════════════════ -->
        <div class="col-lg-3 col-xl-2 border-end bg-white p-0 d-none d-lg-block" style="min-height: calc(100vh - 70px);">
            <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="text-uppercase fw-bold text-muted mb-0" style="font-size: 0.75rem; letter-spacing: 1px;">Your
                Library</h6>
                <a href="/uploads" class="btn btn-sm btn-primary rounded-pill px-3">
                    <i class="bi bi-plus-lg me-1"></i>New
                </a>
            </div>

            <div class="list-group list-group-flush">
                <% if (meetings && meetings.length > 0) { %>
                    <% meetings.forEach(function(m) { %>
                        <a href="/dashboard/<%= m.id %>"
                            class="list-group-item list-group-item-action py-3 <%= (meeting && meeting.id === m.id) ? 'bg-primary bg-opacity-10 border-start border-4 border-primary' : '' %>">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                <h6 class="mb-0 fw-semibold text-dark text-truncate" style="max-width: 140px;"><%= m.title %></h6>
                                <% if (m.status === 'processing') { %>
                                    <span class="badge bg-warning text-dark rounded-pill" style="font-size: 0.55rem;">PROCESSING</span>
                                <% } else if (m.status === 'completed') { %>
                                    <span class="badge bg-success rounded-pill" style="font-size: 0.55rem;">READY</span>
                                <% } else { %>
                                    <span class="badge bg-danger rounded-pill" style="font-size: 0.55rem;">FAILED</span>
                                <% } %>
                            </div>
                            <small class="text-muted"><%= new Date(m.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></small>
                        </a>
                    <% }); %>
                <% } else { %>
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="small mt-2 mb-0">No meetings yet.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════ -->
        <div class="col-lg-9 col-xl-10 p-4 p-lg-5">

        <% if (!meeting) { %>
            <!-- ──── EMPTY STATE ──────────────────────────────────── -->
            <div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 60vh;">
                <div class="mb-4" style="opacity: 0.5;">
                    <i class="bi bi-cloud-upload" style="font-size: 5rem; color: var(--primary);"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">No Meetings Yet</h3>
                <p class="text-muted mb-4" style="max-width: 420px;">
                    Upload your first meeting recording and Briefly will transcribe it, extract key decisions, and create action items automatically.
                </p>
                <a href="/uploads" class="btn btn-primary btn-lg rounded-pill px-5 fw-semibold">
                    <i class="bi bi-upload me-2"></i>Upload a Recording
                </a>
            </div>

        <% } else if (meeting.status === 'processing') { %>
            <!-- ──── PROCESSING STATE ─────────────────────────────── -->
            <div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 60vh;" id="processingState">
                <div class="spinner-border text-primary mb-4" role="status" style="width: 4rem; height: 4rem;">
                    <span class="visually-hidden">Processing...</span>
                </div>
                <h3 class="fw-bold text-dark mb-2">Processing Your Meeting</h3>
                <p class="text-muted mb-1"><strong>"<%= meeting.title %>"</strong></p>
                <p class="text-muted mb-4" style="max-width: 420px;">
                    We're extracting audio, transcribing with AI, and generating insights. This may take a few minutes depending on the file size.
                </p>
                <div class="d-flex gap-3 align-items-center text-muted small">
                    <span class="d-flex align-items-center gap-1"><i class="bi bi-file-earmark-music text-primary"></i> <%= meeting.file_name %></span>
                    <span>•</span>
                    <span>Uploaded <%= new Date(meeting.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></span>
                </div>
            </div>

            <!-- Auto-refresh: poll for completion -->
            <script>
                (function pollStatus() {
                    setTimeout(async () => {
                        try {
                            const res = await fetch('/api/meeting-status/<%= meeting.id %>');
                            const data = await res.json();
                            if (data.status === 'completed' || data.status === 'failed') {
                                window.location.reload();
                            } else {
                                pollStatus();
                            }
                        } catch { pollStatus(); }
                    }, 5000);
                })();
            </script>

        <% } else if (meeting.status === 'failed') { %>
            <!-- ──── FAILED STATE ─────────────────────────────────── -->
            <div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 60vh;">
                <div class="mb-4">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Processing Failed</h3>
                <p class="text-muted mb-2"><strong>"<%= meeting.title %>"</strong></p>
                <% if (meeting.summary) { %>
                    <p class="text-danger small mb-4"><%= meeting.summary %></p>
                <% } %>
                <a href="/uploads" class="btn btn-primary rounded-pill px-4 fw-semibold">
                    <i class="bi bi-arrow-clockwise me-2"></i>Try Again
                </a>
            </div>

        <% } else { %>
            <!-- ══════════════════════════════════════════════════════
                 COMPLETED — Full Meeting View
                 ══════════════════════════════════════════════════════ -->

            <!-- Header -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <div>
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 mb-2 fw-semibold border border-success border-opacity-25">
                        <i class="bi bi-check-circle me-1"></i> Processed
                    </span>
                    <h2 class="fw-bold text-dark mb-1"><%= meeting.title %></h2>
                    <p class="text-muted mb-0">
                        <i class="bi bi-calendar3 me-2"></i><%= new Date(meeting.created_at).toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                        <% if (meeting.duration) { %> • <%= meeting.duration %> duration<% } %>
                        • <i class="bi bi-file-earmark me-1"></i><%= meeting.file_name %>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/uploads" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold"><i class="bi bi-plus-lg me-2"></i>New Upload</a>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-4 border-bottom" id="meetingTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold px-4 py-3 text-dark" id="summary-tab" data-bs-toggle="tab"
                        data-bs-target="#summary" type="button" role="tab">Overview & Insights</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 py-3 text-muted" id="transcript-tab" data-bs-toggle="tab"
                        data-bs-target="#transcript" type="button" role="tab">Full Transcript</button>
                </li>
            </ul>

            <div class="tab-content" id="meetingTabsContent">

                <!-- ──── Overview Tab ─────────────────────────────── -->
                <div class="tab-pane fade show active" id="summary" role="tabpanel">
                    <div class="row g-4">

                        <div class="col-xl-8">
                            <!-- Executive Summary -->
                            <div class="bg-white border rounded-4 p-4 shadow-sm mb-4">
                                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-card-text text-primary"></i> Executive Summary
                                </h5>
                                <p class="text-muted mb-0"><%= meeting.summary || 'No summary available.' %></p>
                            </div>

                            <!-- Key Decisions -->
                            <div class="bg-white border rounded-4 p-4 shadow-sm">
                                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-lightbulb text-warning"></i> Key Decisions
                                </h5>
                                <% if (meeting.key_decisions && meeting.key_decisions.length > 0) { %>
                                    <ul class="list-group list-group-flush">
                                        <% meeting.key_decisions.forEach(function(decision, i) { %>
                                            <li class="list-group-item px-0 text-dark <%= i === meeting.key_decisions.length - 1 ? 'border-bottom-0' : '' %>">
                                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                <%= decision %>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } else { %>
                                    <p class="text-muted mb-0">No key decisions were identified in this meeting.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Action Items -->
                        <div class="col-xl-4">
                            <div class="bg-white border rounded-4 p-4 shadow-sm h-100">
                                <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                                    <i class="bi bi-calendar-check text-primary"></i> Action Items
                                </h5>

                                <% if (meeting.action_items && meeting.action_items.length > 0) { %>
                                    <% meeting.action_items.forEach(function(item) { %>
                                        <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom">
                                            <input class="form-check-input mt-1 border-secondary" type="checkbox"
                                                style="width: 1.25rem; height: 1.25rem;">
                                            <div>
                                                <p class="mb-1 fw-semibold text-dark"><%= typeof item === 'string' ? item : item.task %></p>
                                                <div class="d-flex gap-2 align-items-center flex-wrap">
                                                    <% if (typeof item === 'object' && item.assignee) { %>
                                                        <span class="badge bg-light text-dark border">
                                                            <i class="bi bi-person me-1"></i> <%= item.assignee %>
                                                        </span>
                                                    <% } %>
                                                    <% if (typeof item === 'object' && item.deadline) { %>
                                                        <span class="text-warning small fw-bold">
                                                            <i class="bi bi-clock me-1"></i> <%= item.deadline %>
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <p class="text-muted mb-0">No action items were identified.</p>
                                <% } %>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ──── Transcript Tab ───────────────────────────── -->
                <div class="tab-pane fade" id="transcript" role="tabpanel">
                    <div class="bg-white border rounded-4 shadow-sm p-4">
                        <% if (meeting.transcript) { %>
                            <div class="transcript-entry d-flex gap-3 mb-4">
                                <div class="speaker-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                    style="width: 45px; height: 45px;">
                                    <i class="bi bi-mic"></i>
                                </div>
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h6 class="fw-bold mb-0 text-dark">Full Transcript</h6>
                                        <span class="text-muted small"><%= new Date(meeting.created_at).toLocaleString('en-US', { hour: 'numeric', minute: '2-digit' }) %></span>
                                    </div>
                                    <p class="text-muted mb-0" style="white-space: pre-wrap; line-height: 1.8;"><%= meeting.transcript %></p>
                                </div>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center py-5">No transcript available for this meeting.</p>
                        <% } %>
                    </div>
                </div>

            </div>
        <% } %>

        </div>
    </div>
    </div>

    <%- include("partials/footer") %>