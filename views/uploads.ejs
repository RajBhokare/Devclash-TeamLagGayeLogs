<%- include("partials/header.ejs") %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 rounded-3 mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/upload-process" method="POST" enctype="multipart/form-data" id="uploadForm">

                    <!-- Meeting Title Input -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="meetingTitle">Meeting Title</label>
                        <input type="text" id="meetingTitle" name="meetingTitle"
                            class="form-control form-control-lg bg-white border shadow-sm"
                            placeholder="e.g. Q3 Product Roadmap Planning" required>
                        <div class="form-text text-muted">Give your meeting a descriptive name for easy reference.</div>
                    </div>

                    <div class="upload-dropzone text-center p-5 rounded-4" id="dropArea">

                        <div id="uploadUI">
                            <div class="mb-4">
                                <div class="upload-icon-wrapper mx-auto mb-3">
                                    <i class="bi bi-cloud-arrow-up-fill text-primary"></i>
                                </div>
                                <h4 class="fw-bold mb-1">Upload your files</h4>
                                <p class="text-muted small">Drag and drop your files here, or click to browse.</p>
                            </div>

                            <div class="btn-group shadow-sm">
                                <label
                                    class="btn btn-primary d-flex align-items-center gap-2 px-4 py-2 m-0 cursor-pointer">
                                    <i class="bi bi-file-earmark-plus"></i> Choose File
                                    <input type="file" name="meetingFile" id="fileInput" class="d-none"
                                        accept="video/mp4,audio/*">
                                </label>

                                <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split px-3"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="visually-hidden">Toggle Dropdown</span>
                                </button>

                                <ul class="upload-dropdown-menu dropdown-menu shadow-lg border-0 mt-2 rounded-3">
                                    <li>
                                        <label
                                            class="dropdown-item d-flex align-items-center gap-3 py-2 cursor-pointer">
                                            <i class="bi bi-laptop text-primary"></i> From Device
                                            <input type="file" class="d-none" name="meetingFile" accept="video/mp4,audio/*"
                                                onchange="document.getElementById('fileInput').files = this.files; document.getElementById('fileInput').dispatchEvent(new Event('change'));">
                                        </label>
                                    </li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-3 py-2 text-muted disabled"
                                            href="#">
                                            <i class="bi bi-dropbox"></i> From Dropbox <span
                                                class="badge bg-light text-secondary ms-auto"
                                                style="font-size: 0.6rem;">SOON</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-3 py-2 text-muted disabled"
                                            href="#">
                                            <i class="bi bi-google"></i> Google Drive <span
                                                class="badge bg-light text-secondary ms-auto"
                                                style="font-size: 0.6rem;">SOON</span>
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-3 py-2" href="#">
                                            <i class="bi bi-link-45deg text-primary"></i> From URL
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Selected file info -->
                            <div id="selectedFileInfo" class="d-none mt-3 text-muted small">
                                <i class="bi bi-file-earmark-check text-success me-1"></i>
                                <span id="selectedFileName"></span>
                                <button type="button" class="btn btn-link btn-sm text-danger p-0 ms-2" id="clearFile">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        </div>

                        <div id="processingUI" class="d-none py-4">
                            <div class="spinner-border text-primary mb-3" role="status"
                                style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <h5 class="fw-bold text-dark">Uploading & Processing...</h5>
                            <p class="text-muted small">Your file is being uploaded. You'll be redirected to the dashboard shortly.</p>
                        </div>

                    </div>

                    <!-- Submit button (shown after file is selected) -->
                    <div id="submitSection" class="d-none mt-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-semibold" id="submitBtn">
                            <i class="bi bi-rocket-takeoff me-2"></i>Process Meeting
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <section class="py-5 bg-white animate-on-scroll">
        <div class="container py-4">
            <div class="row align-items-center g-4 justify-content-between">
                <div class="col-lg-5 pe-lg-4">
                    <span
                        class="badge bg-primary bg-opacity-10 text-primary text-uppercase px-2 py-1 rounded-pill mb-3 fw-bold"
                        style="letter-spacing: 0.5px; font-size: 0.7rem;">
                        How does it work?
                    </span>
                    <h2 class="fw-bold mb-4 text-dark" style="font-size: 2.25rem;">How to process a recording?</h2>
                    <div class="mb-3">
                        <div class="text-primary text-uppercase fw-bold mb-1"
                            style="font-size: 0.7rem; letter-spacing: 1px;">Step 1</div>
                        <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">1. Name & Upload your file</h5>
                        <p class="text-muted small mb-0">Give your meeting a title, then drag and drop your recording into the
                            upload area, or click to browse your device.</p>
                        <div class="border-top border-primary opacity-25 my-3"
                            style="border-style: dotted; border-width: 2px;"></div>
                    </div>
                    <div class="mb-3">
                        <div class="text-primary text-uppercase fw-bold mb-1"
                            style="font-size: 0.7rem; letter-spacing: 1px;">Step 2</div>
                        <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">2. AI Analysis</h5>
                        <p class="text-muted small mb-0">Briefly automatically transcribes the audio, identifies
                            key decisions, and extracts action items using AI.</p>
                        <div class="border-top border-primary opacity-25 my-3"
                            style="border-style: dotted; border-width: 2px;"></div>
                    </div>
                    <div>
                        <div class="text-primary text-uppercase fw-bold mb-1"
                            style="font-size: 0.7rem; letter-spacing: 1px;">Step 3</div>
                        <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">3. Review on Dashboard</h5>
                        <p class="text-muted small mb-0">View your summary, key decisions, and action items on the
                            dashboard — all extracted automatically from your recording.</p>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0">
                    <div class="integration-hub mx-auto">
                        <div class="hub-center">
                            <i class="bi bi-arrow-repeat text-primary" style="font-size: 4rem;"></i>
                        </div>
                        <div class="hub-node node-1 bg-warning text-dark"><i class="bi bi-file-earmark-play"></i> MP4
                        </div>
                        <div class="hub-node node-2 bg-success text-white"><i class="bi bi-file-earmark-music"></i> M4A
                        </div>
                        <div class="hub-node node-3 text-dark" style="background: #fbbf24;"><i
                                class="bi bi-file-earmark-music"></i> WAV</div>
                        <div class="hub-node node-4 text-white" style="background: #f97316;"><i
                                class="bi bi-collection-play"></i> Audio & Video</div>
                        <div class="hub-node node-5 text-white bg-primary"><i class="bi bi-file-earmark-music"></i> MP3
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        const fileInput = document.getElementById('fileInput');
        const titleInput = document.getElementById('meetingTitle');
        const selectedFileInfo = document.getElementById('selectedFileInfo');
        const selectedFileName = document.getElementById('selectedFileName');
        const clearFileBtn = document.getElementById('clearFile');
        const submitSection = document.getElementById('submitSection');
        const uploadForm = document.getElementById('uploadForm');

        fileInput.addEventListener('change', function () {
            if (this.files.length > 0) {
                selectedFileName.textContent = this.files[0].name;
                selectedFileInfo.classList.remove('d-none');
                submitSection.classList.remove('d-none');
            }
        });

        clearFileBtn.addEventListener('click', function () {
            fileInput.value = '';
            selectedFileInfo.classList.add('d-none');
            submitSection.classList.add('d-none');
        });

        uploadForm.addEventListener('submit', function (e) {
            if (!fileInput.files.length) {
                e.preventDefault();
                alert('Please select a file first.');
                return;
            }
            if (!titleInput.value.trim()) {
                e.preventDefault();
                titleInput.focus();
                titleInput.classList.add('is-invalid');
                return;
            }
            document.getElementById('uploadUI').classList.add('d-none');
            document.getElementById('processingUI').classList.remove('d-none');
            submitSection.classList.add('d-none');
        });

        titleInput.addEventListener('input', function () {
            this.classList.remove('is-invalid');
        });
    </script>

    <%- include("partials/footer.ejs") %>